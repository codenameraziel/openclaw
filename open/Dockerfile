# Usa Node.js oficial
FROM node:22-alpine

# Define diretório de trabalho
WORKDIR /usr/src/app

# Copia package.json e instala dependęncias
COPY package*.json ./
RUN npm install --production

# Copia o restante do código
COPY . .

# Porta padrăo do gateway
EXPOSE 18790

# Comando de inicializaçăo
CMD ["npm", "start"]
